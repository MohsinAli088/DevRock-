{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://uk1.airanode.cloud:25768/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "http://uk1.airanode.cloud:25768/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
